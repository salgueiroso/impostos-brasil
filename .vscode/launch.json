{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug TypeScript",
            "runtimeArgs": [
                "-r",
                "ts-node/register",
                "--eval",
                "require('./src/exemplo.ts').exemplo()"
            ],
            "args": [
                "${workspaceFolder}/src/exemplo.ts"
            ],
            "sourceMaps": true,
            "cwd": "${workspaceFolder}"
        }
    ]
}