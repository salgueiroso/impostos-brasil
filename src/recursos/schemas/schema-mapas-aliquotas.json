{
    "$schema": "https://json-schema.org/draft/2019-09/schema",
    "$id": "https://raw.githubusercontent.com/salgueiroso/impostos-brasil/refs/heads/main/src/recursos/schemas/schema-mapas-aliquotas.json",
    "title": "Mapa de aliquotas",
    "description": "Representa um mapa de aliquotas de impostos",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "MapaVigencia"
    ],
    "properties": {
        "$schema": {
            "type": "string"
        },
        "MapaVigencia": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/mapa"
            },
            "minItems": 1,
            "uniqueItems": true
        }
    },
    "$defs": {
        "chave": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "Ano": {
                    "type": "integer",
                    "minimum": 2010,
                    "description": "Ano de vigencia"
                },
                "Mes": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 12,
                    "description": "Mes de vigencia"
                }
            },
            "required": [
                "Ano",
                "Mes"
            ]
        },
        "faixa": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "Aliquota": {
                    "type": "number",
                    "minimum": 0
                },
                "ValorTeto": {
                    "oneOf": [
                        {
                            "type": "number",
                            "minimum": 0
                        },
                        {
                            "type": "string",
                            "minLength": 1,
                            "pattern": "^Infinity$"
                        }
                    ]
                }
            },
            "required": [
                "Aliquota",
                "ValorTeto"
            ]
        },
        "mapa": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "Fonte": {
                    "type": "string",
                    "format": "uri",
                    "pattern": "^https?://.+"
                },
                "Chave": {
                    "$ref": "#/$defs/chave"
                },
                "Valor": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/faixa"
                    },
                    "minItems": 1,
                    "uniqueItems": true,
                    "description": "Faixas de aliquotas"
                }
            },
            "required": [
                "Fonte",
                "Chave",
                "Valor"
            ]
        }
    }
}