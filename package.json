{
  "name": "impostos-brasil",
  "version": "1.2.1",
  "description": "Esta biblioteca simplifica os calculos dos impostos INSS e IR do Brasil",
  "author": "Acacio Salgueiro",
  "license": "MIT",
  "keywords": [
    "clt",
    "brasil",
    "brazil",
    "inss",
    "irpf",
    "irpj",
    "imposto",
    "impostos",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/salgueiroso/impostos-brasil/issues"
  },
  "homepage": "https://github.com/salgueiroso/impostos-brasil",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "/dist"
  ],
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salgueiroso/impostos-brasil.git"
  },
  "scripts": {
    "validate:json": "ajv validate -s src/recursos/schemas/schema-mapas-aliquotas.json -d 'src/recursos/*.json'",
    "prebuild": "npm run validate:json",
    "build": "tsdown",
    "postbuild": "typedoc",
    "watch": "tsdown --watch",
    "start": "node -e \"import('./dist/index.js').then(m => m.exemplo())\"",
    "start:watch": "nodemon --watch src --ext js,ts --exec \"npm run build && npm run start\"",
    "test": "jest --ci --coverage",
    "test:watch": "jest --ci --watchAll --coverage",
    "postinstall": "rm -Rf /tmp/node_modules && mv ./node_modules /tmp && ln -s /tmp/node_modules ./node_modules",
    "clean": "rm -Rf /tmp/node_modules ./node_modules ./dist ./reports ./coverage",
    "clean:git": "git clean -fdx"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "ajv": "^8.20.0",
    "ajv-cli": "^5.0.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.11",
    "shx": "^0.4.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3"
  }
}